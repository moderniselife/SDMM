# =============================================================================
# SchroDrive Media Manager — Environment Variables
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# =============================================================================

# --- App ---
PORT=8686
PUID=1000
PGID=1000
TZ=Australia/Sydney

# --- Plex ---
PLEX_URL=http://192.168.1.124:32400
PLEX_TOKEN=your_plex_token_here

# --- Tautulli ---
TAUTULLI_URL=http://192.168.1.124:8181
TAUTULLI_API_KEY=your_tautulli_api_key_here

# --- qBittorrent ---
QBITTORRENT_URL=http://qbittorrent:8080
QBITTORRENT_USERNAME=admin
QBITTORRENT_PASSWORD=your_qbittorrent_password_here

# --- TMDB (poster metadata) ---
TMDB_API_KEY=your_tmdb_api_key_here

# --- NVIDIA ---
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=video,compute,utility

# --- Encoding ---
# Options: cpu, nvenc, av1
ENCODER_DEFAULT=nvenc

# --- Paths (inside container) ---
MEDIA_ROOT=/media
CLOUD_REALDEBRID=/cloud/realdebrid
CLOUD_TORBOX=/cloud/torbox
CONFIG_DIR=/config

# --- Logging ---
LOG_LEVEL=info
